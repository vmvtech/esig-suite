{
  "name": "@e-sig/uuaid",
  "version": "0.1.1",
  "description": "Opt-in UUAID adapter for @e-sig/core \u2014 stamp the acting agent's UUAID into the audit log and anchor the audit hash-chain head to UUAID's Polygon-anchored ledger (encrypted, hash-only).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "uuaid",
    "agent-identity",
    "ai-agent",
    "audit-log",
    "anchoring",
    "tamper-proof",
    "pdf",
    "esignature",
    "self-contained",
    "esign"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vmvtech/esig-suite.git",
    "directory": "packages/esig-uuaid"
  },
  "homepage": "https://github.com/vmvtech/esig-suite/tree/main/packages/esig-uuaid#readme",
  "dependencies": {
    "@uuaid/sdk": "^0.1.0",
    "@uuaid/vault": "^0.1.0"
  },
  "peerDependencies": {
    "@e-sig/core": "^0.5.0 || ^0.6.0 || ^0.7.0"
  },
  "devDependencies": {
    "@e-sig/core": "^0.7.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
