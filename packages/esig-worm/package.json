{
  "name": "@e-sig/worm",
  "version": "0.1.0",
  "description": "WORM (write-once-read-many) archival adapter for @e-sig/core \u2014 store signed PDFs and audit-chain exports in an S3 Object Lock bucket with COMPLIANCE-mode retention set atomically on every put. Technical controls in the style of SEC 17a-4(f) / FINRA 4511. Dependency-light: bring your own S3 client.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "worm",
    "object-lock",
    "s3",
    "sec-17a-4",
    "finra",
    "compliance",
    "immutable",
    "retention",
    "audit-log",
    "archival",
    "pdf",
    "esignature",
    "esign"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vmvtech/esig-suite.git",
    "directory": "packages/esig-worm"
  },
  "homepage": "https://github.com/vmvtech/esig-suite/tree/main/packages/esig-worm#readme",
  "peerDependencies": {
    "@e-sig/core": "^0.6.0 || ^0.7.0"
  },
  "devDependencies": {
    "@e-sig/core": "^0.7.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
