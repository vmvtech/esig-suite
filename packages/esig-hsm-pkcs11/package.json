{
  "name": "@e-sig/hsm-pkcs11",
  "version": "0.1.0",
  "description": "PKCS#11 HSM adapter for @e-sig/core — keep the RSA signing key inside AWS CloudHSM, YubiHSM 2, SoftHSM2, or any Cryptoki token via the ExternalSigner seam; the private key never enters process memory.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "pkcs11",
    "hsm",
    "cloudhsm",
    "yubihsm",
    "softhsm",
    "cryptoki",
    "pdf",
    "esignature",
    "pkcs7",
    "pades",
    "self-contained",
    "esign"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vmvtech/esig-suite.git",
    "directory": "packages/esig-hsm-pkcs11"
  },
  "homepage": "https://github.com/vmvtech/esig-suite/tree/main/packages/esig-hsm-pkcs11#readme",
  "peerDependencies": {
    "@e-sig/core": "^0.7.0",
    "pkcs11js": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "pkcs11js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@e-sig/core": "^0.7.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
